<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".StudentsInformationFragment">

    <ImageView
        android:id="@+id/photo_student"
        android:layout_width="match_parent"
        android:layout_height="300dp"/>

    <TextView
        android:id="@+id/textview_name_student"
        android:hint="Фамилия и имя студента: "
        android:layout_marginTop="310dp"
        android:layout_width="match_parent"
        android:layout_height="100dp"/>

    <TextView
        android:id="@+id/textview_info_student"
        android:hint="Информация о студенте: "
        android:layout_marginTop="420dp"
        android:layout_width="match_parent"
        android:layout_height="300dp"/>

</FrameLayout>